# ─────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN VALUES
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Database — Railway provides this automatically when you add PostgreSQL
# For local dev, use: postgresql://user:password@localhost:5432/maxwell_portfolio
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# On Railway, set to: https://your-app.railway.app

# Admin credentials (used by seed script)
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="choose-a-strong-password"

# Email — for contact form notifications (optional)
# Using Gmail: enable App Passwords in Google Account settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your@gmail.com"
CONTACT_TO="your@email.com"
